# Copia a .env y rellena. NUNCA subas .env.

# IA (obligatoria) — key gratis en https://aistudio.google.com
GEMINI_API_KEY=
# Modelo opcional (default gemini-2.5-flash)
# EXTRACTOR_MODEL=gemini-2.5-flash

# Auth interna del servicio: la app ContaScan debe enviar el header
# X-Intake-Key con este valor en cada request (/extraer, /chat). Genera
# un secreto aleatorio largo. Se exige a partir de la fase I2.
INTAKE_SERVICE_KEY=
